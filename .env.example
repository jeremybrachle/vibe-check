# Core app
APP_NAME=The Vibe Check
APP_ENV=development
DATABASE_URL=sqlite:///./vibe_check.db
REFRESH_EVERY_HOURS=4
HN_MAX_PER_FEED=30
HN_MAX_TOTAL=100
HN_INCLUDE_TOP_COMMENTS=true
HN_TOP_COMMENTS_PER_STORY=3

# LLM provider: none | auto | heuristic | openai | ollama
#   none      — skip AI summary entirely; ai_summary will always be ""
#   auto      — uses OpenAI if key set, Ollama if configured, otherwise none
#   heuristic — same as none but reserved for future keyword-based summaries
#   openai    — requires OPENAI_API_KEY below
#   ollama    — requires a running Ollama instance at OLLAMA_BASE_URL
LLM_PROVIDER=none

# OpenAI (optional)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Ollama (optional local LLM)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# CORS: comma-separated allowed origins for the API
# Use * for local dev. Restrict to your actual domains in production.
# Example: ALLOWED_ORIGINS=https://vibecheck.example.com,https://portfolio.example.com
ALLOWED_ORIGINS=*

# Admin token: protects POST /api/v1/admin/* endpoints
# Leave empty to disable the check (fine for local dev).
# Set to any long random string in production: openssl rand -hex 32
ADMIN_TOKEN=
